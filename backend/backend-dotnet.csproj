<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net8.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>backend_dotnet</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="ClosedXML" Version="0.104.2" />
    <PackageReference Include="Microsoft.ML.OnnxRuntime" Version="1.20.0" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="models\onnx\**\*.onnx" CopyToOutputDirectory="PreserveNewest" />
    <Content Include="models\onnx\**\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
